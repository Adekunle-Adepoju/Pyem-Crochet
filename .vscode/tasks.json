{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Deploy to Live",
      "type": "shell",
      "command": "git add . && git commit -m 'update ${input:message}' && git push",
      "problemMatcher": [],
      "inputs": [
        {
          "id": "message",
          "type": "promptString",
          "description": "Commit message",
          "default": "site update"
        }
      ]
    }
  ]
}